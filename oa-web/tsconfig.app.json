{
  "compilerOptions": {
    "target": "ES2022", "module": "ESNext", "moduleResolution": "Bundler", "strict": true, "noEmit": true,
    "skipLibCheck": true, "jsx": "preserve", "resolveJsonModule": true, "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"], "types": ["vitest/globals"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
}
